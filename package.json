{
  "name": "agent-skills-pipeline",
  "version": "0.5.0",
  "description": "Structured, multi-agent development pipeline for AI coding tools, with an opencode plugin entrypoint.",
  "type": "module",
  "main": "./.opencode/plugins/pipeline.js",
  "exports": {
    ".": "./.opencode/plugins/pipeline.js"
  },
  "files": [
    ".codex/",
    ".codex-plugin/",
    ".opencode/plugins/pipeline.js",
    ".opencode/agents/",
    "agents/",
    "skills/",
    "!skills/**/node_modules/**",
    "!skills/**/.annotations/**",
    "!skills/**/.vite/**",
    "hooks/",
    "scripts/install-codex.sh",
    "scripts/install-opencode.sh",
    "pipeline.config.example.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "check:opencode-plugin": "node --check .opencode/plugins/pipeline.js",
    "check:codex-installer": "bash -n scripts/install-codex.sh",
    "check:installers": "bash -n scripts/install-codex.sh scripts/install-cursor.sh scripts/install-opencode.sh",
    "check:agents": "node scripts/generate-agents.mjs --check",
    "test:task-dag": "node --test scripts/validate-task-dag.test.mjs",
    "test:installers": "node --test scripts/install-validator.test.mjs",
    "test:adaptive-contract": "node --test scripts/adaptive-contract.test.mjs",
    "verify": "npm run check:opencode-plugin && npm run check:installers && npm run check:agents && npm test && npm run test:task-dag && npm run test:installers && npm run test:adaptive-contract"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "agent-skills",
    "multi-agent",
    "pipeline",
    "tdd",
    "review"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/ambrovia/agent-skills-pipeline",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ambrovia/agent-skills-pipeline.git"
  }
}
