{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash hooks/session-start.sh gemini" }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|replace|edit",
        "hooks": [
          { "type": "command", "command": "bash hooks/edit-streak.sh gemini" },
          { "type": "command", "command": "node hooks/thrash-detector.mjs gemini" }
        ]
      }
    ]
  }
}
