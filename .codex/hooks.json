{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash hooks/session-start.sh codex" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          { "type": "command", "command": "bash hooks/edit-streak.sh codex" }
        ]
      }
    ]
  }
}
