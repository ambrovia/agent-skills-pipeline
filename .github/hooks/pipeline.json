{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "bash hooks/session-start.sh copilot",
        "command": "bash hooks/session-start.sh copilot"
      }
    ],
    "postToolUse": [
      {
        "matcher": "edit|write|patch|replace|create",
        "type": "command",
        "bash": "bash hooks/edit-streak.sh copilot",
        "command": "bash hooks/edit-streak.sh copilot"
      },
      {
        "matcher": "edit|write|patch|replace|create",
        "type": "command",
        "bash": "node hooks/thrash-detector.mjs copilot",
        "command": "node hooks/thrash-detector.mjs copilot"
      }
    ]
  }
}
