{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "bash ${CURSOR_PLUGIN_ROOT}/hooks/session-start.sh cursor"
      }
    ],
    "postToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "command": "bash ${CURSOR_PLUGIN_ROOT}/hooks/edit-streak.sh cursor"
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "command": "node ${CURSOR_PLUGIN_ROOT}/hooks/thrash-detector.mjs cursor"
      }
    ]
  }
}
